*.bak
*~

# Theme zip files (large binaries)
*.zip

# Generated product images (experiments)
pomelo-*.png
pomelo-*.jpg
generate-pomelo*.mjs

# Generated plugin guides (exports)
docs/plugin-guides/*.html
docs/plugin-guides/*.pdf
docs/plugin-guides/*.md
wp-content/plugins/*/docs/*.pdf

# QuickBooks integration docs (client proposals)
docs/QUICKBOOKS-*.md
docs/QuickBooks-*.docx
docs/generate_*.py

# QBO data backups (financial data — never commit)
qbo-backups/
# WooCommerce backups (customer PII: names, emails, addresses — never commit)
wc-backups/
# Tax-code change rollback/plan files (contain QBO item ids)
taxcode-change-*.json
# Transaction retag plan/rollback files (contain txn ids)
txn-retag-*.json
# QBO item SKU-set rollback files
qbo-item-sku-set-*.json
# QBO apply/rollback files (contain QBO item ids) — never commit
qbo-*.applied.json
# Crosswalk CSV backups (per-run snapshots)
*.csv.bak-*
# Python bytecode cache
__pycache__/
